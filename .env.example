# ─── Database ──────────────────────────────────────────────────────────
# SQLite lokal, tidak perlu XAMPP/MySQL
DATABASE_URL="file:./prisma/dev.db"

# ─── NextAuth ──────────────────────────────────────────────────────────
# URL aplikasi (sesuaikan dengan IP/domain server Anda)
NEXTAUTH_URL="http://localhost:3000"

# Secret unik untuk menandatangani JWT session
# WAJIB diganti di production! Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-string-random-minimal-32-karakter"

# ─── App Settings ──────────────────────────────────────────────────────
# Password default untuk akun baru yang dibuat oleh Admin
# Pengguna baru WAJIB diminta ganti password setelah login pertama
DEFAULT_USER_PASSWORD="pbb12345"

# ─── Catatan Keamanan ──────────────────────────────────────────────────
# 1. JANGAN pernah commit file .env atau .env.local ke GitHub!
# 2. File ini (.env.example) hanya sebagai template referensi.
# 3. Salin file ini menjadi .env.local dan isi nilainya.
