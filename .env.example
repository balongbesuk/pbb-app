# Environment
NODE_ENV="production"

# Database - SQLite
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
# Ganti dengan URL domain Anda, misal: https://pbb-desa.com
NEXTAUTH_URL="http://localhost:3000"
# Generate secret baru dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"

# App Settings
# Password default untuk admin saat pertama kali install / seed
ADMIN_PASSWORD="ganti-password-admin-awal-yang-kuat"
# Password default untuk user baru (PENARIK) atau reset password
DEFAULT_USER_PASSWORD="ganti-password-default-user-yang-kuat"

# Storage Configuration
# Ganti dengan path absolut ke folder storage di PC Anda
# PENTING: Gunakan folder DI LUAR root project agar build time Next.js cepat.
STORAGE_ROOT="C:/pbb-app-storage"

# Reverse Proxy / CDN
# Set true hanya jika aplikasi berada di belakang proxy tepercaya
# seperti Nginx, Vercel, Cloudflare, atau load balancer internal.
TRUST_PROXY="false"

# Cloudflare Turnstile
# Dapatkan kunci Turnstile gratis di dashboard Cloudflare Anda.
# Untuk testing lokal, Anda bisa menggunakan testing keys resmi Cloudflare berikut (selalu sukses):
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Web Push Notifications
# Generate VAPID keys menggunakan perintah: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="isi-dengan-public-key"
VAPID_PRIVATE_KEY="isi-dengan-private-key"
VAPID_SUBJECT="mailto:admin@desa-anda.com"
