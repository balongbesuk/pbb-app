  "scripts": {
    "dev": "npx prisma generate && next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "postinstall": "node scripts/init.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:errors": "eslint src/ --quiet",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "verify:security": "npm audit --audit-level=moderate",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:vacuum": "node scripts/vacuum.mjs"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not ie 11"
