# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Database (Local SQLite)
/prisma/*.db
/prisma/*.db-journal
dev.db
dev.db.bak

# Temporary/Cache
.eslintcache
/eslint.log
/tmp/

# Templates (Always keep)
!/public/template-pbb.xlsx

# App build logs
build.log
build_log.txt

# User Uploads
/public/uploads/*
!/public/uploads/.gitkeep
/public/uploads/avatars/*
!/public/uploads/avatars/.gitkeep
/public/uploads/logos/*
!/public/uploads/logos/.gitkeep
/public/arsip-pbb/
/public/pbb_process_log.txt
/temp_extracted.txt
test_qr.js
/storage/
/backups/
map-data/
public/maps/
